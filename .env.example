SENDER_TITLE=Business Development Manager

# CQC API (free, no key needed)
CQC_API_BASE=https://api.cqc.org.uk/public/v1

# Optional: Google Custom Search (for finding emails on agency websites)
GOOGLE_API_KEY=
GOOGLE_CX=
